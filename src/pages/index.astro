---
import BaseLayout from '../layouts/BaseLayout.astro';

// 读取 public/images 下的图片
const images = [
  { src: '/images/portrait/ChatGPT Image 2026年4月22日 22_53_40.png', prompt: 'Portrait - 2026-04-22 22:53', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月22日 22_57_19.png', prompt: 'Portrait - 2026-04-22 22:57', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月24日 12_07_54.png', prompt: 'Portrait - 2026-04-24 12:07', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月24日 12_41_38.png', prompt: 'Portrait - 2026-04-24 12:41', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 08_26_23.png', prompt: 'Portrait - 2026-04-27 08:26', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 08_32_04.png', prompt: 'Portrait - 2026-04-27 08:32', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 08_38_30.png', prompt: 'Portrait - 2026-04-27 08:38', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 17_50_05.png', prompt: 'Portrait - 2026-04-27 17:50', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 17_52_19.png', prompt: 'Portrait - 2026-04-27 17:52', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月27日 18_04_20.png', prompt: 'Portrait - 2026-04-27 18:04', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月28日 14_44_59.png', prompt: 'Portrait - 2026-04-28 14:44', category: 'portrait' },
  { src: '/images/portrait/ChatGPT Image 2026年4月28日 14_59_38.png', prompt: 'Portrait - 2026-04-28 14:59', category: 'portrait' },
];

const categories = ['全部', '人像', '风景', '建筑', '其他'];
---

<BaseLayout title="Rubin — AI Art Portfolio">
  <header class="border-b border-border px-6 py-5">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <h1 class="font-serif text-2xl text-text">Rubin</h1>
      <p class="text-sm text-text/60">AI Art Portfolio</p>
    </div>
  </header>

  <nav class="px-6 py-4 border-b border-border">
    <div class="max-w-6xl mx-auto flex gap-4">
      {categories.map((cat, i) => (
        <button
          class:list={[
            'px-4 py-2 text-sm rounded-full transition-colors',
            i === 0 ? 'bg-primary text-white' : 'bg-surface text-text/70 hover:bg-border'
          ]}
          data-category={cat === '全部' ? 'all' : cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </nav>

  <main class="max-w-6xl mx-auto p-6">
    <div id="gallery" class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
      {images.map((img, i) => (
        <div
          class="gallery-item break-inside-avoid group cursor-pointer relative overflow-hidden rounded-lg border border-border bg-surface shadow-sm hover:shadow-md transition-shadow"
          data-category={img.category}
          data-index={i}
        >
          <img
            src={img.src}
            alt={img.prompt}
            class="w-full object-cover hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-text/0 group-hover:bg-text/60 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
            <span class="text-white font-mono text-xs px-3 py-2 bg-text/80 rounded backdrop-blur-sm">
              查看
            </span>
          </div>
        </div>
      ))}
    </div>
  </main>

  <footer class="border-t border-border px-6 py-5 text-center text-sm text-text/50">
    <p>Rubin — {new Date().getFullYear()}</p>
  </footer>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-text/80 backdrop-blur-sm hidden z-50 items-center justify-center p-8">
    <button id="close-lightbox" class="absolute top-4 right-4 text-white/70 hover:text-white text-3xl">&times;</button>
    <div class="max-w-4xl max-h-full">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg" />
      <p id="lightbox-prompt" class="text-white/60 text-center mt-4 font-mono text-sm"></p>
    </div>
  </div>
</BaseLayout>

<script>
  const items = document.querySelectorAll('.gallery-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxPrompt = document.getElementById('lightbox-prompt');
  const closeBtn = document.getElementById('close-lightbox');
  const navBtns = document.querySelectorAll('nav button');

  // Lightbox
  items.forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img') as HTMLImageElement;
      const prompt = item.querySelector('img')?.getAttribute('alt') || '';
      lightboxImg.src = img.src;
      lightboxPrompt.textContent = prompt;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
    });
  });

  closeBtn?.addEventListener('click', () => {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    }
  });

  // Filter
  navBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');
      navBtns.forEach(b => b.classList.remove('bg-primary', 'text-white'));
      btn.classList.add('bg-primary', 'text-white');

      items.forEach(item => {
        if (cat === 'all' || item.getAttribute('data-category') === cat) {
          (item as HTMLElement).style.display = '';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>