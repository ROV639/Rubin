---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Rubin Studio — Museum Entrance">
  <main class="site-shell">
    <section class="entrance-card" data-enter-target="/museum/" tabindex="0" aria-label="Enter Rubin Studio Museum">
      <nav class="museum-nav" aria-label="Rubin Museum">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <i class="mark-shape mark-shape-a"></i>
            <i class="mark-shape mark-shape-b"></i>
          </span>
          <span>Rubin Studio</span>
        </a>
        <a class="nav-pill" href="/museum/"><span>Enter Museum</span></a>
      </nav>

      <div class="entrance">
        <div class="entrance-copy">
          <p class="kicker">Living Museum</p>
          <h1>
            Rubin Studio
            <span>Living Museum</span>
          </h1>
        </div>

        <div class="door-scene" data-source="Original AI-generated cubist museum entrance artwork">
          <div class="gallery-photo">
            <img src="/images/museum-sources/entrance-cubist-original.webp" alt="Original cubist museum entrance artwork used as Rubin Studio entrance cover" />
          </div>
          <div class="stage-panel">
            <b>Identity Hall</b>
            <span>Original cubist entrance artwork</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const entranceCard = document.querySelector('[data-enter-target]');
  const enterMuseum = () => {
    const target = entranceCard?.getAttribute('data-enter-target');
    if (target) window.location.href = target;
  };

  entranceCard?.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof Element && target.closest('a, button, input, textarea, select, label')) return;
    enterMuseum();
  });

  entranceCard?.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter' && event.key !== ' ') return;
    const target = event.target;
    if (target instanceof Element && target.closest('a, button, input, textarea, select, label')) return;
    event.preventDefault();
    enterMuseum();
  });
</script>

<style>
  :global(body) {
    background: #f2ede3 url('/images/museum-sources/picasso-paper-bg.svg') center / cover fixed no-repeat;
  }

  .site-shell {
    position: relative;
    min-height: 100vh;
    padding: 14px;
    color: #2b2b28;
    overflow: hidden;
  }

  .site-shell::before,
  .site-shell::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .site-shell::before {
    background:
      linear-gradient(127deg, transparent 0 10%, rgba(94,124,116,.23) 10% 21%, transparent 21% 100%),
      linear-gradient(32deg, transparent 0 63%, rgba(166,90,74,.2) 63% 74%, transparent 74% 100%),
      linear-gradient(154deg, transparent 0 38%, rgba(194,160,90,.17) 38% 48%, transparent 48% 100%),
      radial-gradient(rgba(43,43,40,.09) .8px, transparent .8px);
    background-size: auto, auto, auto, 18px 18px;
    opacity: .92;
    z-index: -1;
  }

  .site-shell::after {
    background:
      linear-gradient(68deg, transparent 0 8%, rgba(43,43,40,.09) 8% 8.5%, transparent 8.5%),
      linear-gradient(112deg, transparent 0 82%, rgba(94,124,116,.18) 82% 94%, transparent 94%),
      linear-gradient(22deg, transparent 0 3%, rgba(194,160,90,.2) 3% 12%, transparent 12%);
    mix-blend-mode: multiply;
    opacity: .7;
    z-index: -1;
  }

  .entrance-card {
    position: relative;
    width: min(1540px, 100%);
    min-height: calc(100vh - 28px);
    margin: 0 auto;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(128deg, rgba(242,237,227,.88) 0 42%, rgba(94,124,116,.2) 42% 49%, transparent 49% 100%),
      linear-gradient(26deg, transparent 0 68%, rgba(166,90,74,.14) 68% 79%, transparent 79% 100%),
      linear-gradient(120deg, rgba(242,237,227,.76), rgba(242,237,227,.5)),
      rgba(242,237,227,.5);
    box-shadow: 0 34px 110px rgba(43, 43, 40, .14);
    cursor: pointer;
    overflow: clip;
  }

  .entrance-card::before,
  .entrance-card::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .entrance-card::before {
    width: 40vw;
    height: 32vw;
    right: -11vw;
    top: 11vh;
    background:
      linear-gradient(145deg, rgba(94,124,116,.34) 0 38%, transparent 38%),
      linear-gradient(42deg, transparent 0 44%, rgba(194,160,90,.28) 44% 65%, transparent 65%),
      linear-gradient(116deg, transparent 0 58%, rgba(166,90,74,.23) 58% 100%);
    clip-path: polygon(0 11%, 72% 0, 100% 54%, 50% 100%, 7% 76%);
  }

  .entrance-card::after {
    width: 28vw;
    height: 24vw;
    left: -8vw;
    bottom: -9vw;
    background:
      linear-gradient(78deg, rgba(194,160,90,.25), transparent 52%),
      linear-gradient(136deg, transparent 0 38%, rgba(94,124,116,.22) 38% 100%);
    clip-path: polygon(12% 0, 100% 28%, 76% 86%, 0 100%);
  }

  .museum-nav {
    position: relative;
    min-height: 76px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 12px 24px;
    border-bottom: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(114deg, rgba(94,124,116,.18) 0 16%, transparent 16% 58%, rgba(194,160,90,.16) 58% 66%, transparent 66%),
      rgba(242,237,227,.78);
    backdrop-filter: blur(18px);
    z-index: 2;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 13px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .brand-mark {
    position: relative;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    background:
      linear-gradient(135deg, #2b2b28 0 39%, #5e7c74 39% 63%, #a65a4a 63% 100%);
    border: 1px solid rgba(43,43,40,.42);
    box-shadow: 0 2px 0 rgba(43,43,40,.18);
    transform: rotate(45deg);
    overflow: hidden;
  }

  .mark-shape {
    position: absolute;
    display: block;
    opacity: .92;
  }

  .mark-shape-a {
    inset: -3px 15px 17px -2px;
    background: #c2a05a;
    clip-path: polygon(0 0, 100% 18%, 72% 100%, 0 78%);
  }

  .mark-shape-b {
    inset: 14px -4px -3px 12px;
    background: #5e7c74;
    clip-path: polygon(18% 0, 100% 15%, 100% 100%, 0 70%);
  }

  .nav-pill {
    position: relative;
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    border: 1px solid rgba(43,43,40,.2);
    background:
      linear-gradient(128deg, rgba(94,124,116,.32) 0 28%, rgba(242,237,227,.72) 28% 58%, rgba(166,90,74,.26) 58% 72%, rgba(194,160,90,.3) 72% 100%);
    color: #2b2b28;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px rgba(242,237,227,.36);
    transition: transform .22s ease, border-color .22s ease, filter .22s ease;
    overflow: hidden;
    z-index: 1;
  }

  .nav-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(43,43,40,.08) 1px, transparent 1px),
      radial-gradient(rgba(43,43,40,.16) .65px, transparent .65px);
    background-size: 18px 18px, 12px 12px;
    mix-blend-mode: multiply;
    opacity: .7;
  }

  .nav-pill span {
    position: relative;
    z-index: 1;
  }

  .nav-pill:hover {
    transform: translateY(-2px);
    border-color: #2b2b28;
    filter: contrast(1.04) saturate(1.04);
  }

  .entrance {
    position: relative;
    z-index: 1;
    min-height: calc(100vh - 106px);
    display: grid;
    grid-template-columns: minmax(0, .84fr) minmax(520px, 1.16fr);
    gap: 34px;
    align-items: center;
    padding: 56px 48px 42px;
  }

  .kicker {
    color: #a67832;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 18px 0 20px;
    color: #2b2b28;
    font-size: clamp(58px, 9vw, 118px);
    font-weight: 400;
    line-height: .9;
    text-wrap: balance;
  }

  h1 span {
    display: block;
    margin-top: 8px;
    color: #a65a4a;
    font-family: 'Rubin Carter', sans-serif;
    font-size: clamp(28px, 4vw, 54px);
  }

  .door-scene {
    position: relative;
    min-height: 620px;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(180deg, rgba(255,250,240,.7), rgba(231,219,198,.4)),
      #efe6d5;
    box-shadow: 0 26px 74px rgba(43,43,40,.14);
    overflow: hidden;
  }

  .gallery-photo {
    position: absolute;
    inset: 6% 6% 18%;
    border: 12px solid rgba(242,237,227,.86);
    box-shadow: 0 24px 70px rgba(43,43,40,.16);
    overflow: hidden;
    z-index: 3;
  }

  .gallery-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .stage-panel {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 24px;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 18px;
    padding: 14px 16px;
    color: #2b2b28;
    border: 1px solid rgba(43,43,40,.22);
    background: rgba(242,237,227,.88);
    backdrop-filter: blur(12px);
    z-index: 4;
  }

  .stage-panel b {
    font-family: 'Rubin Carter', sans-serif;
  }

  .stage-panel span {
    color: #575247;
  }

  @media (max-width: 1100px) {
    .entrance {
      grid-template-columns: 1fr;
    }
    .door-scene {
      min-height: 540px;
    }
  }

  @media (max-width: 680px) {
    .site-shell {
      padding: 8px;
    }
    .museum-nav,
    .entrance {
      padding-left: 18px;
      padding-right: 18px;
    }
    .museum-nav {
      grid-template-columns: 1fr;
    }
    .entrance {
      min-height: auto;
      padding-top: 34px;
    }
    .door-scene {
      min-height: 460px;
    }
    .gallery-photo {
      inset: 6% 6% 24%;
      border-width: 8px;
    }
    .stage-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
