---

<BaseLayout title="Awesome GPT Image 2 Prompts">
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden">
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <!-- Badge -->
      <div class="inline-block text-xs tracking-[0.3em] uppercase px-4 py-1.5 rounded-full border border-[var(--accent-border)] mb-8" style="background: var(--accent-muted); color: var(--accent);">
        GPT Image 2 · 精选提示词
      </div>

      <!-- Title -->
      <h1 class="text-5xl md:text-7xl font-light tracking-[0.1em] leading-none mb-6" style="font-family: 'Cormorant Garamond', serif; color: var(--gold-text);">
        Awesome Prompts
      </h1>

      <!-- Subtitle -->
      <p class="text-lg font-light leading-relaxed max-w-xl mx-auto mb-10" style="color: var(--text-dim);">
        359+ 高质量 GPT-Image-2 提示词<br/>
        涵盖电商、广告、人像、海报等7大分类
      </p>

      <!-- Search -->
      <div class="relative max-w-md mx-auto">
        <input
          type="text"
          id="search-input"
          placeholder="搜索提示词..."
          class="w-full px-6 py-4 rounded-full border text-center text-sm tracking-wider transition-all duration-300"
          style="background: var(--bg-surface); border-color: var(--accent-border); color: var(--text-primary);"
        />
        <span class="absolute left-6 top-1/2 -translate-y-1/2" style="color: var(--text-dim);">🔍</span>
      </div>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="sticky top-0 z-40 py-4 px-6" style="background: rgba(7, 18, 9, 0.95); backdrop-filter: blur(12px); border-bottom: 1px solid var(--accent-border);">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-wrap justify-center gap-2" id="category-tabs">
        {categories.map((cat, i) => (
          <button
            data-category={cat.key}
            class:list={[
              'px-5 py-2 text-xs tracking-[0.15em] uppercase rounded-full transition-all duration-300 border',
              i === 0
                ? 'text-[var(--bg-deep)] border-[var(--accent)]'
                : 'border-[var(--accent-border)] hover:border-[var(--accent)]'
            ]}
            style={i === 0 ? 'background: var(--accent);' : `color: var(--text-dim);`}
          >
            <span class="mr-1">{cat.icon}</span>{cat.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Prompts Grid -->
  <section class="max-w-7xl mx-auto px-6 py-12">
    <div id="prompts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {prompts.map((p) => (
        <div
          class="prompt-card rounded-xl overflow-hidden border transition-all duration-400 cursor-pointer group"
          data-category={p.category}
          data-title={p.title.toLowerCase()}
          style="background: var(--bg-surface); border-color: var(--accent-border);"
          onclick="togglePrompt(this)"
        >
          <!-- Image -->
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={p.image}
              alt={p.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          </div>

          <!-- Content -->
          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] tracking-[0.2em] uppercase px-2 py-1 rounded-full border" style="color: var(--accent); border-color: var(--accent-border);">
                {categories.find(c => c.key === p.category)?.label}
              </span>
              <a href={p.source} target="_blank" class="text-[10px] tracking-wider" style="color: var(--text-dim);">
                {p.author}
              </a>
            </div>

            <h3 class="text-lg font-light tracking-wide mb-2" style="color: var(--text-primary); font-family: 'Cormorant Garamond', serif;">
              {p.title}
            </h3>

            <p class="text-xs leading-relaxed mb-4" style="color: var(--text-dim);">
              {p.zh}
            </p>

            <!-- Prompt Preview -->
            <div class="prompt-preview text-xs p-3 rounded-lg mb-4 overflow-hidden" style="background: rgba(0,0,0,0.3); color: var(--text-dim);">
              <p class="line-clamp-3">{p.prompt}</p>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-3 border-t" style="border-color: var(--accent-border);">
              <button
                onclick="event.stopPropagation(); copyPrompt(this)"
                data-prompt={p.prompt}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-3 py-1.5 rounded-full border transition-all duration-300 hover:border-[var(--accent)]"
                style="border-color: var(--accent-border); color: var(--accent);"
              >
                <span>📋</span> 复制
              </button>
              <button class="text-xs" style="color: var(--text-dim);">点击展开 ↓</button>
            </div>
          </div>

          <!-- Full Prompt (Hidden) -->
          <div class="prompt-full hidden px-5 pb-5">
            <div class="text-xs p-4 rounded-lg overflow-auto max-h-[300px]" style="background: rgba(0,0,0,0.4); color: var(--text-primary);">
              <pre class="whitespace-pre-wrap text-xs leading-relaxed">{p.prompt}</pre>
            </div>
            <div class="flex items-center justify-between mt-4 pt-3 border-t" style="border-color: var(--accent-border);">
              <button
                onclick="event.stopPropagation(); copyPrompt(this)"
                data-prompt={p.prompt}
                class="text-xs tracking-wider uppercase flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
                style="background: var(--accent); color: var(--bg-deep);"
              >
                <span>✓</span> 复制完整提示词
              </button>
              <button onclick="event.stopPropagation(); togglePrompt(this.closest('.prompt-card'))" class="text-xs px-3 py-1.5 rounded-full border" style="border-color: var(--accent-border); color: var(--text-dim);">
                收起
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-2xl mb-2" style="color: var(--gold-text); font-family: 'Cormorant Garamond', serif;">暂无匹配</p>
      <p class="text-sm" style="color: var(--text-dim);">尝试其他关键词或分类</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t py-10 px-6" style="border-color: var(--accent-border);">
    <div class="max-w-6xl mx-auto text-center">
      <p class="text-xs tracking-widest uppercase mb-4" style="color: var(--gold-text);">Awesome GPT Image 2 Prompts</p>
      <p class="text-xs" style="color: var(--text-dim);">
        基于 <a href="https://github.com/EvoLinkAI/awesome-gpt-image-2-API-and-Prompts" target="_blank" class="underline" style="color: var(--accent);">EvolinkAI/awesome-gpt-image-2</a> · 仅供学习参考
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .prompt-card:hover {
    border-color: var(--accent) !important;
    box-shadow: 0 0 30px var(--glow);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg-deep);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--accent-border);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--accent);
  }
</style>

<script>
  const tabs = document.querySelectorAll('#category-tabs button');
  const cards = document.querySelectorAll('.prompt-card');
  const searchInput = document.getElementById('search-input');
  const emptyState = document.getElementById('empty-state');

  // Category filter
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.category;

      tabs.forEach(t => {
        t.style.background = 'transparent';
        t.style.color = 'var(--text-dim)';
        t.style.borderColor = 'var(--accent-border)';
      });
      tab.style.background = 'var(--accent)';
      tab.style.color = 'var(--bg-deep)';
      tab.style.borderColor = 'var(--accent)';

      cards.forEach(card => {
        if (cat === 'all' || card.dataset.category === cat) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });

      checkEmpty();
    });
  });

  // Search
  searchInput?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();

    cards.forEach(card => {
      const title = card.dataset.title || '';
      if (title.includes(q) || q === '') {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });

    checkEmpty();
  });

  function checkEmpty() {
    const visible = [...cards].filter(c => c.style.display !== 'none');
    emptyState?.classList.toggle('hidden', visible.length > 0);
  }

  // Toggle prompt expand/collapse
  function togglePrompt(card) {
    const preview = card.querySelector('.prompt-preview');
    const full = card.querySelector('.prompt-full');
    const toggle = card.querySelector('.flex.items-center.justify-between.pt-3.border-t button:last-child');

    if (full?.classList.contains('hidden')) {
      full.classList.remove('hidden');
      preview?.classList.add('hidden');
      if (toggle) toggle.textContent = '收起';
    } else {
      full?.classList.add('hidden');
      preview?.classList.remove('hidden');
      if (toggle) toggle.textContent = '点击展开 ↓';
    }
  }

  // Copy prompt
  function copyPrompt(btn) {
    const prompt = btn.dataset.prompt;
    navigator.clipboard.writeText(prompt).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = '<span>✓</span> 已复制';
      setTimeout(() => {
        btn.innerHTML = original;
      }, 1500);
    });
  }

  // Make functions global
  (window as any).togglePrompt = togglePrompt;
  (window as any).copyPrompt = copyPrompt;
</script>
