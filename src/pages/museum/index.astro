---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { museumRooms } from '../../data/museumRooms';
---

<BaseLayout title="Rubin Studio — Museum Home">
  <main class="site-shell">
    <div class="site">
      <header class="museum-top">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <i class="mark-shape mark-shape-a"></i>
            <i class="mark-shape mark-shape-b"></i>
          </span>
          <span>Rubin Studio</span>
        </a>
        <div class="nav-links">
          <a href="/">Entrance</a>
          <a href="/studio">Studio</a>
        </div>
      </header>

      <section class="home-hero">
        <div>
          <p class="kicker">Main hall / six rooms</p>
          <h1>Wonder is the beginning.</h1>
        </div>
      </section>

      <nav class="room-menu" aria-label="Rubin museum rooms">
        {museumRooms.map((room) => (
          <a class="room-link" href={`/museum/${room.slug}/`} style={`--room-accent: ${room.accent}; --room-secondary: ${room.secondary}`} data-source={room.source}>
            <span class="room-no">Hall {room.no}</span>
            <span class="room-image">
              <img src={room.image} alt={`${room.zh} source visual`} loading="eager" />
            </span>
            <span class="room-copy">
              <strong>{room.title}</strong>
              <p>{room.summary}</p>
            </span>
          </a>
        ))}
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f2ede3 url('/images/museum-sources/picasso-paper-bg.svg') center / cover fixed no-repeat;
  }

  .site-shell {
    position: relative;
    min-height: 100vh;
    padding: 14px;
    --rubin-ink: #203949;
    --rubin-ink-soft: #4f5d64;
    --rubin-brand-deep: #1d3849;
    color: var(--rubin-ink);
    overflow: hidden;
  }

  .site-shell::before,
  .site-shell::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .site-shell::before {
    background:
      linear-gradient(127deg, transparent 0 10%, rgba(94,124,116,.23) 10% 21%, transparent 21% 100%),
      linear-gradient(32deg, transparent 0 63%, rgba(166,90,74,.2) 63% 74%, transparent 74% 100%),
      linear-gradient(154deg, transparent 0 38%, rgba(194,160,90,.17) 38% 48%, transparent 48% 100%),
      radial-gradient(rgba(43,43,40,.09) .8px, transparent .8px);
    background-size: auto, auto, auto, 18px 18px;
    opacity: .92;
    z-index: -1;
  }

  .site-shell::after {
    background:
      linear-gradient(68deg, transparent 0 8%, rgba(43,43,40,.09) 8% 8.5%, transparent 8.5%),
      linear-gradient(112deg, transparent 0 82%, rgba(94,124,116,.18) 82% 94%, transparent 94%),
      linear-gradient(22deg, transparent 0 3%, rgba(194,160,90,.2) 3% 12%, transparent 12%);
    mix-blend-mode: multiply;
    opacity: .7;
    z-index: -1;
  }

  .site {
    position: relative;
    width: min(1540px, 100%);
    margin: 0 auto 54px;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(128deg, rgba(242,237,227,.88) 0 42%, rgba(94,124,116,.18) 42% 49%, transparent 49% 100%),
      linear-gradient(26deg, transparent 0 70%, rgba(166,90,74,.13) 70% 80%, transparent 80% 100%),
      linear-gradient(120deg, rgba(242,237,227,.76), rgba(242,237,227,.5)),
      rgba(242,237,227,.5);
    box-shadow: 0 34px 110px rgba(43, 43, 40, .14);
    overflow: clip;
  }

  .site::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(112deg, transparent 0 61%, rgba(95,147,97,.2) 61% 73%, transparent 73%),
      linear-gradient(22deg, transparent 0 12%, rgba(194,160,90,.18) 12% 22%, transparent 22%),
      linear-gradient(145deg, transparent 0 78%, rgba(166,90,74,.13) 78% 88%, transparent 88%);
    pointer-events: none;
  }

  .museum-top,
  .home-hero,
  .room-menu {
    position: relative;
    z-index: 1;
  }

  .museum-top {
    min-height: 76px;
    display: grid;
    grid-template-columns: 250px 1fr;
    align-items: center;
    gap: 18px;
    padding: 12px 24px;
    border-bottom: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(114deg, rgba(94,124,116,.18) 0 16%, transparent 16% 58%, rgba(194,160,90,.16) 58% 66%, transparent 66%),
      rgba(242,237,227,.78);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 13px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .brand-mark {
    position: relative;
    width: 40px;
    height: 34px;
    display: grid;
    place-items: center;
    background:
      linear-gradient(135deg, rgba(194,160,90,.28) 0 24%, transparent 24% 100%),
      linear-gradient(90deg, #1d3849, #24485b);
    border: 1px solid rgba(29,56,73,.58);
    box-shadow: 0 2px 0 rgba(32,57,73,.18);
    overflow: hidden;
  }

  .brand-mark::before,
  .brand-mark::after,
  .mark-shape {
    position: absolute;
    display: block;
    content: "";
  }

  .brand-mark::before {
    inset: 5px auto 5px 18px;
    width: 6px;
    background: #c2a05a;
    clip-path: polygon(18% 0, 100% 8%, 82% 100%, 0 92%);
  }

  .brand-mark::after {
    inset: 6px 7px 4px auto;
    width: 7px;
    background: #a65a4a;
    clip-path: polygon(10% 0, 100% 10%, 90% 100%, 0 88%);
  }

  .mark-shape-a {
    inset: 7px auto 3px 7px;
    width: 7px;
    background: #6f8b84;
    clip-path: polygon(28% 0, 100% 9%, 72% 100%, 0 90%);
  }

  .mark-shape-b {
    display: none;
  }

  .nav-links {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
  }

  .nav-links a {
    position: relative;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(128deg, rgba(94,124,116,.22) 0 28%, rgba(255,250,240,.62) 28% 70%, rgba(194,160,90,.22) 70% 100%);
    color: var(--rubin-ink-soft);
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px rgba(242,237,227,.32);
  }

  .kicker {
    color: #a67832;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .home-hero {
    max-width: 980px;
    padding: 68px 48px 34px;
  }

  h1 {
    margin: 12px 0 0;
    color: var(--rubin-ink);
    font-size: clamp(32px, 5.4vw, 72px);
    font-weight: 400;
    line-height: 1.02;
    white-space: nowrap;
  }

  .room-menu {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    padding: 0 48px 68px;
  }

  .room-link {
    position: relative;
    min-height: 296px;
    display: grid;
    grid-template-rows: auto 148px 1fr;
    gap: 14px;
    padding: 22px;
    border: 1px solid rgba(43,43,40,.2);
    background:
      linear-gradient(180deg, rgba(255,250,240,.82), rgba(231,219,198,.68)),
      #efe6d5;
    color: var(--rubin-ink);
    transition: transform .25s ease, box-shadow .25s ease, background .25s ease;
    overflow: hidden;
  }

  .room-link::before {
    display: none;
  }

  .room-link > * {
    position: relative;
    z-index: 1;
  }

  .room-link:hover {
    transform: translateY(-4px) rotate(-.4deg);
    box-shadow: 0 20px 44px rgba(43,43,40,.14);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--room-accent) 8%, #fffaf0), rgba(231,219,198,.78)),
      #efe6d5;
  }

  .room-link:nth-child(even):hover {
    transform: translateY(-4px) rotate(.4deg);
  }

  .room-no {
    width: 116px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    color: var(--rubin-ink);
    border: 1px solid rgba(32,57,73,.34);
    background:
      linear-gradient(128deg, rgba(32,57,73,.28) 0 24%, rgba(242,237,227,.82) 24% 55%, rgba(194,160,90,.32) 55% 100%);
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px rgba(242,237,227,.35);
  }

  .room-link:nth-child(2) .room-no {
    background:
      linear-gradient(118deg, rgba(166,90,74,.28) 0 31%, rgba(242,237,227,.82) 31% 66%, rgba(94,124,116,.29) 66% 100%);
  }

  .room-link:nth-child(3) .room-no {
    background:
      linear-gradient(98deg, rgba(194,160,90,.31) 0 26%, rgba(242,237,227,.84) 26% 50%, rgba(32,57,73,.24) 50% 100%);
  }

  .room-link:nth-child(4) .room-no {
    background:
      linear-gradient(136deg, rgba(94,124,116,.28) 0 22%, rgba(242,237,227,.84) 22% 62%, rgba(166,90,74,.25) 62% 100%);
  }

  .room-link:nth-child(5) .room-no {
    background:
      linear-gradient(108deg, rgba(32,57,73,.24) 0 35%, rgba(194,160,90,.28) 35% 52%, rgba(242,237,227,.84) 52% 100%);
  }

  .room-link:nth-child(6) .room-no {
    background:
      linear-gradient(142deg, rgba(166,90,74,.24) 0 18%, rgba(94,124,116,.26) 18% 46%, rgba(242,237,227,.86) 46% 100%);
  }

  .room-image {
    position: relative;
    display: block;
    min-height: 148px;
    margin: 0 -8px;
    border: 2px solid var(--rubin-ink);
    background: #efe6d5;
    overflow: hidden;
  }

  .room-image::after {
    display: none;
  }

  .room-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform .45s ease, filter .45s ease;
  }

  .room-link:hover .room-image img {
    transform: scale(1.08);
  }

  .room-copy {
    display: grid;
    align-content: end;
  }

  .room-link strong {
    display: block;
    color: var(--rubin-ink);
    font-family: 'Rubin Carter', sans-serif;
    font-size: clamp(25px, 2.5vw, 38px);
    font-weight: 400;
    line-height: 1.05;
  }

  .room-link p {
    margin: 12px 0 0;
    color: var(--rubin-ink-soft);
    line-height: 1.55;
  }

  @media (prefers-reduced-motion: reduce) {
    .room-link,
    .room-image img {
      transition: none;
    }
  }

  @media (max-width: 980px) {
    .room-menu {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .site-shell {
      padding: 8px;
    }
    .museum-top,
    .home-hero,
    .room-menu {
      padding-left: 18px;
      padding-right: 18px;
    }
    .museum-top {
      grid-template-columns: 1fr;
    }
    .nav-links {
      justify-content: flex-start;
    }
    .room-menu {
      grid-template-columns: 1fr;
      padding-bottom: 34px;
    }
  }
</style>
