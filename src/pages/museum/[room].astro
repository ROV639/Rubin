---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { museumRooms } from '../../data/museumRooms';

export function getStaticPaths() {
  return museumRooms.map((room) => ({
    params: { room: room.slug },
    props: { room },
  }));
}

const { room } = Astro.props;
---

<BaseLayout title={`${room.zh} — Rubin Studio Museum`}>
  <main class="site-shell" style={`--room-accent: ${room.accent}; --room-secondary: ${room.secondary}`}>
    <div class="site">
      <nav class="room-nav">
        <a class="brand" href="/museum/">
          <span class="brand-mark" aria-hidden="true">
            <i class="mark-shape mark-shape-a"></i>
            <i class="mark-shape mark-shape-b"></i>
          </span>
          <span>{room.title}</span>
        </a>
        <div class="nav-links">
          <a href="/museum/">Main Hall</a>
          <a href="/">Entrance</a>
          <a href="/studio">Studio</a>
        </div>
      </nav>

      <section class="room-stage">
        <div class="room-frame" data-source={room.source}>
          <img class="room-bg" src={room.image} alt={`${room.zh} source visual`} />
          <div class="room-wash"></div>
          <div class="stage-panel">
            <b>{room.title}</b>
            <span>{room.role}</span>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  :global(body) {
    background: #f2ede3 url('/images/museum-sources/picasso-paper-bg.svg') center / cover fixed no-repeat;
  }

  .site-shell {
    position: relative;
    min-height: 100vh;
    padding: 14px;
    color: #2b2b28;
    overflow: hidden;
  }

  .site-shell::before,
  .site-shell::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .site-shell::before {
    background:
      linear-gradient(127deg, transparent 0 10%, rgba(94,124,116,.23) 10% 21%, transparent 21% 100%),
      linear-gradient(32deg, transparent 0 63%, rgba(166,90,74,.2) 63% 74%, transparent 74% 100%),
      linear-gradient(154deg, transparent 0 38%, rgba(194,160,90,.17) 38% 48%, transparent 48% 100%),
      radial-gradient(rgba(43,43,40,.09) .8px, transparent .8px);
    background-size: auto, auto, auto, 18px 18px;
    opacity: .92;
    z-index: -1;
  }

  .site-shell::after {
    background:
      linear-gradient(68deg, transparent 0 8%, rgba(43,43,40,.09) 8% 8.5%, transparent 8.5%),
      linear-gradient(112deg, transparent 0 82%, rgba(94,124,116,.18) 82% 94%, transparent 94%),
      linear-gradient(22deg, transparent 0 3%, rgba(194,160,90,.2) 3% 12%, transparent 12%);
    mix-blend-mode: multiply;
    opacity: .7;
    z-index: -1;
  }

  .site {
    position: relative;
    width: min(1540px, 100%);
    min-height: calc(100vh - 28px);
    margin: 0 auto;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(128deg, rgba(242,237,227,.88) 0 42%, rgba(94,124,116,.18) 42% 49%, transparent 49% 100%),
      linear-gradient(26deg, transparent 0 70%, rgba(166,90,74,.13) 70% 80%, transparent 80% 100%),
      linear-gradient(120deg, rgba(242,237,227,.76), rgba(242,237,227,.5)),
      rgba(242,237,227,.5);
    box-shadow: 0 34px 110px rgba(43, 43, 40, .14);
    overflow: clip;
  }

  .site::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(112deg, transparent 0 61%, color-mix(in srgb, var(--room-accent) 22%, transparent) 61% 73%, transparent 73%),
      linear-gradient(22deg, transparent 0 12%, color-mix(in srgb, var(--room-secondary) 18%, transparent) 12% 22%, transparent 22%),
      linear-gradient(145deg, transparent 0 78%, rgba(166,90,74,.12) 78% 88%, transparent 88%);
    pointer-events: none;
  }

  .room-nav,
  .room-stage {
    position: relative;
    z-index: 1;
  }

  .room-nav {
    min-height: 76px;
    display: grid;
    grid-template-columns: 260px 1fr;
    align-items: center;
    gap: 18px;
    padding: 12px 24px;
    border-bottom: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(114deg, color-mix(in srgb, var(--room-accent) 18%, transparent) 0 16%, transparent 16% 58%, color-mix(in srgb, var(--room-secondary) 18%, transparent) 58% 66%, transparent 66%),
      rgba(242,237,227,.78);
    backdrop-filter: blur(18px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 13px;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .brand-mark {
    position: relative;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    background:
      linear-gradient(135deg, #2b2b28 0 39%, #5e7c74 39% 63%, #a65a4a 63% 100%);
    border: 1px solid rgba(43,43,40,.42);
    box-shadow: 0 2px 0 rgba(43,43,40,.18);
    transform: rotate(45deg);
    overflow: hidden;
  }

  .mark-shape {
    position: absolute;
    display: block;
    opacity: .92;
  }

  .mark-shape-a {
    inset: -3px 15px 17px -2px;
    background: #c2a05a;
    clip-path: polygon(0 0, 100% 18%, 72% 100%, 0 78%);
  }

  .mark-shape-b {
    inset: 14px -4px -3px 12px;
    background: #5e7c74;
    clip-path: polygon(18% 0, 100% 15%, 100% 100%, 0 70%);
  }

  .nav-links {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
  }

  .nav-links a {
    position: relative;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(128deg, color-mix(in srgb, var(--room-accent) 18%, transparent) 0 28%, rgba(255,250,240,.62) 28% 70%, color-mix(in srgb, var(--room-secondary) 18%, transparent) 70% 100%);
    color: #575247;
    font-family: 'Rubin Carter', sans-serif;
    font-size: 12px;
    letter-spacing: .06em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px rgba(242,237,227,.32);
  }

  .room-stage {
    min-height: calc(100vh - 104px);
    display: grid;
    align-items: center;
    padding: 42px 48px 56px;
  }

  .room-frame {
    position: relative;
    min-height: min(760px, calc(100vh - 196px));
    border: 1px solid rgba(43,43,40,.18);
    background:
      linear-gradient(135deg, rgba(242,237,227,.7), color-mix(in srgb, var(--room-accent) 16%, transparent)),
      linear-gradient(24deg, transparent 0 52%, color-mix(in srgb, var(--room-secondary) 23%, transparent) 52% 63%, transparent 63%),
      #efe6d5;
    box-shadow: 0 26px 74px rgba(43,43,40,.14);
    overflow: hidden;
  }

  .room-frame::before,
  .room-frame::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 2;
  }

  .room-frame::before {
    inset: 0;
    background:
      linear-gradient(90deg, rgba(43,43,40,.055) 1px, transparent 1px),
      linear-gradient(0deg, rgba(43,43,40,.045) 1px, transparent 1px),
      radial-gradient(rgba(43,43,40,.12) .72px, transparent .72px);
    background-size: 42px 42px, 42px 42px, 15px 15px;
    opacity: .62;
  }

  .room-frame::after {
    right: 3%;
    top: 7%;
    width: 34%;
    height: 34%;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--room-accent) 34%, transparent) 0 42%, transparent 42%),
      linear-gradient(46deg, transparent 0 48%, color-mix(in srgb, var(--room-secondary) 32%, transparent) 48% 72%, transparent 72%),
      linear-gradient(116deg, transparent 0 58%, rgba(166,90,74,.18) 58% 100%);
    clip-path: polygon(0 11%, 72% 0, 100% 54%, 50% 100%, 7% 76%);
    mix-blend-mode: multiply;
  }

  .room-bg {
    position: absolute;
    inset: 8% 7% 16%;
    width: 86%;
    height: 76%;
    object-fit: cover;
    border: 12px solid rgba(242,237,227,.86);
    box-shadow: 0 24px 70px rgba(43,43,40,.16);
    z-index: 1;
  }

  .room-wash {
    display: none;
  }

  .stage-panel {
    position: absolute;
    left: 24px;
    right: 24px;
    bottom: 24px;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 18px;
    padding: 16px;
    color: #2b2b28;
    border: 1px solid rgba(43,43,40,.22);
    background:
      linear-gradient(118deg, color-mix(in srgb, var(--room-accent) 18%, transparent) 0 18%, rgba(242,237,227,.86) 18% 72%, color-mix(in srgb, var(--room-secondary) 18%, transparent) 72% 100%);
    backdrop-filter: blur(12px);
    z-index: 4;
  }

  .stage-panel b {
    font-family: 'Rubin Carter', sans-serif;
  }

  .stage-panel span {
    color: #575247;
  }

  @media (max-width: 1100px) {
    .room-frame {
      min-height: 540px;
    }
  }

  @media (max-width: 680px) {
    .site-shell {
      padding: 8px;
    }
    .room-nav,
    .room-stage {
      padding-left: 18px;
      padding-right: 18px;
    }
    .room-nav {
      grid-template-columns: 1fr;
    }
    .nav-links {
      justify-content: flex-start;
    }
    .room-stage {
      min-height: auto;
      padding-top: 34px;
    }
    .room-frame {
      min-height: 460px;
    }
    .stage-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
